{
	"extends": "@rocket.chat/tsconfig/base.json",
	"compilerOptions": {
		"module": "node18",
		"moduleResolution": "node16",
		"rewriteRelativeImportExtensions": true,

		"outDir": "./dist",

		"allowJs": false,

		"esModuleInterop": true,
		"erasableSyntaxOnly": true,
		"verbatimModuleSyntax": true,

		"lib": ["ES2024", "ESNext.Collection"]
	}
}
