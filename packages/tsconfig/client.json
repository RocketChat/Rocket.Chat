{
	"$schema": "https://json.schemastore.org/tsconfig",
	"extends": "./base.json",
	"compilerOptions": {
		"module": "esnext",
		"rootDir": "${configDir}",

		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,

		"preserveSymlinks": true,

		"jsx": "react-jsx",
		"lib": ["ESNext", "DOM", "DOM.Iterable"],
	}
}
