{
	"extends": ["@rocket.chat/eslint-config", "@rocket.chat/eslint-config/react"],
	"ignorePatterns": ["dist"],
	"overrides": [
		{
			"files": ["**/*.ts", "**/*.tsx", "**/*.cts", "**/*.mts"],
			"parserOptions": {
				"project": null
			},
			"rules": {
				"@typescript-eslint/no-misused-promises": "off",
				"@typescript-eslint/no-floating-promises": "off"
			}
		}
	]
}
