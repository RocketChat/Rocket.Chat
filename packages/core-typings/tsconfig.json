{
	"extends": "@rocket.chat/tsconfig/server.json",
	"compilerOptions": {
		"target": "es2020",
		"lib": [
			"dom",
			"dom.iterable",
			"es2020"
		],
		"declaration": true,
		"rootDir": "./src",
		"outDir": "./dist",
		"plugins": [
			{
				"transform": "typia/lib/transform"
			}
		]
	},
	"include": [
		"./src/**/*"
	]
}