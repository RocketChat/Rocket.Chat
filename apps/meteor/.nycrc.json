{
	"report-dir": "./coverage",
	"temp-dir": "./.nyc_output",
	"reporter": ["html", "lcov", "text", "text-summary"],
	"extension": [".ts", ".tsx", ".js", ".jsx"],
	"exclude": [
		"**/*.spec.ts",
		"**/*.test.ts",
		"**/*.spec.js",
		"**/*.test.js",
		"**/*.stories.tsx",
		"**/*.stories.ts",
		"tests/**",
		"node_modules/**",
		"**/*.d.ts",
		"**/mocks/**",
		"**/fixtures/**",
		"**/__mocks__/**"
	],
	"all": false,
	"check-coverage": false,
	"sourceMap": true,
	"instrument": false,
	"cache": true,
	"cacheDir": "./.nyc_cache"
}
